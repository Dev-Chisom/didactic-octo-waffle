{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.auto-viral.example/schemas/dialogue_expansion.json",
  "title": "DialogueExpansion",
  "description": "Expanded scene: narration + dialogue lines. Maps to Script.scenes (SceneSpec).",
  "type": "object",
  "required": ["scene_number", "narration"],
  "properties": {
    "scene_number": { "type": "integer", "minimum": 1 },
    "narration": {
      "type": "string",
      "description": "Narrator text; describes visual action. Becomes scene_type=narration or part of combined text."
    },
    "dialogue": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["character_id", "line"],
        "properties": {
          "character": { "type": "string", "description": "Display name" },
          "character_id": { "type": "string", "description": "Slug for lip-sync" },
          "emotion": { "type": "string" },
          "line": { "type": "string", "description": "Short, natural line for TTS" }
        }
      },
      "description": "Character lines in order; each can become a dialogue scene for lip-sync"
    }
  }
}
